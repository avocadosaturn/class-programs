   "source": [
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "15b9e8fe",
   "metadata": {},
   "outputs": [],
   "source": [
    "# your analytic function\n",
    "def f(q):\n",
    "    return 1 / (np.exp(q) + 1)\n",
    "\n",
    "q_vals = np.linspace(0, 20, 100)\n",
    "f_vals = f(q_vals)\n",
    "\n",
    "np.savetxt(\"SL_FDpsd.dat\", np.column_stack((q_vals, f_vals)))"
   ]
  },
